# Multi-stage build for FastAPI backend
FROM python:3.11-slim as builder

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir --user -r requirements.txt

# Production stage
FROM python:3.11-slim as production

# Create non-root user
RUN groupadd -r reagent && useradd -r -g reagent reagent

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    libpq5 \
    curl \
    dumb-init \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy installed packages from builder
COPY --from=builder /root/.local /home/reagent/.local

# Copy application code
COPY src/ ./src/
COPY sql/ ./sql/

# Create logs directory
RUN mkdir -p logs && chown -R reagent:reagent /app

# Switch to non-root user
USER reagent

# Make sure scripts in .local are usable
ENV PATH=/home/reagent/.local/bin:$PATH

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f --max-time 5 http://localhost:8000/api/v1/health/ready || exit 1

# Expose ports
EXPOSE 8000

# Set Python path to include src directory
ENV PYTHONPATH=/app/src

# Default command
CMD ["uvicorn", "reagent.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]