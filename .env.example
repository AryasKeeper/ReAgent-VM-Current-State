# ReAgent Sydney - Complete Production Environment Configuration
# Copy this to .env and configure for your deployment environment

# =============================================================================
# CORE APPLICATION SETTINGS
# =============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-super-secure-secret-key-min-32-chars

# =============================================================================
# DATABASE CONFIGURATION - PostgreSQL + TimescaleDB
# =============================================================================
POSTGRES_PASSWORD=secure_postgres_password
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=256MB
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# =============================================================================
# REDIS CONFIGURATION - Caching and Pub/Sub
# =============================================================================
REDIS_PASSWORD=secure_redis_password
REDIS_PORT=6379
REDIS_MAXMEMORY=512mb
CACHE_TTL=3600

# =============================================================================
# WEAVIATE VECTOR DATABASE CONFIGURATION
# =============================================================================
WEAVIATE_PORT=8080
WEAVIATE_METRICS_PORT=2112
WEAVIATE_ANONYMOUS_ACCESS=true
WEAVIATE_APIKEY_ENABLED=false
WEAVIATE_API_KEY=your_weaviate_api_key
WEAVIATE_API_USERS=admin,readonly
WEAVIATE_MEMORY_LIMIT=4G
WEAVIATE_CPU_LIMIT=2.0
WEAVIATE_MAX_PROCS=4
WEAVIATE_LOG_LEVEL=info

# =============================================================================
# EXTERNAL API KEYS - Real Estate Data Sources
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
DOMAIN_API_KEY=your_domain_com_au_api_key
REA_API_KEY=your_realestate_com_au_api_key
CORELOGIC_API_KEY=your_corelogic_api_key
NSW_LPI_API_KEY=your_nsw_lpi_api_key

# =============================================================================
# APPLICATION SERVICE CONFIGURATION
# =============================================================================
API_PORT=8000
API_WORKERS=4
API_WORKER_CONNECTIONS=1000
API_MEMORY_LIMIT=2G
API_CPU_LIMIT=1.5

# Health Monitor Configuration
HEALTH_MONITOR_PORT=8001
HEALTH_CHECK_INTERVAL=30
HEALTH_RECOVERY_ENABLED=true
FEATURE_FLAGS_ENABLED=true

# Agent Orchestrator Configuration
AGENT_CONCURRENCY=5
AGENT_TIMEOUT=300
ORCHESTRATION_MODE=async
ORCHESTRATOR_MEMORY_LIMIT=3G
ORCHESTRATOR_CPU_LIMIT=2.0

# =============================================================================
# CELERY BACKGROUND PROCESSING
# =============================================================================
CELERY_CONCURRENCY=4
CELERY_PREFETCH_MULTIPLIER=1
CELERY_MAX_TASKS_PER_CHILD=1000
CELERY_MEMORY_LIMIT=1G
CELERY_CPU_LIMIT=1.0
CELERY_BEAT_SCHEDULE=/app/celerybeat-schedule/celerybeat-schedule

# =============================================================================
# MONITORING AND METRICS
# =============================================================================
# Prometheus Configuration
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d
PROMETHEUS_RETENTION_SIZE=10GB
PROMETHEUS_LOG_LEVEL=info
PROMETHEUS_MEMORY_LIMIT=2G
PROMETHEUS_CPU_LIMIT=1.0

# Grafana Configuration
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_PASSWORD=secure_grafana_password
GRAFANA_DB_MAX_CONN=10
GRAFANA_DB_MAX_IDLE=2
GRAFANA_METRICS_USER=admin
GRAFANA_METRICS_PASSWORD=secure_metrics_password
GRAFANA_LOG_LEVEL=info
GRAFANA_FEATURES=publicDashboards
GRAFANA_MEMORY_LIMIT=1G
GRAFANA_CPU_LIMIT=0.5

# =============================================================================
# NETWORK AND SECURITY CONFIGURATION
# =============================================================================
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Network Configuration
NETWORK_SUBNET=172.20.0.0/16
NETWORK_GATEWAY=172.20.0.1
NETWORK_MTU=1500

# =============================================================================
# DATA STORAGE AND BACKUP CONFIGURATION
# =============================================================================
DATA_DIR=./data
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# =============================================================================
# ALERTING AND NOTIFICATIONS
# =============================================================================
# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#reagent-alerts
SLACK_USERNAME=ReAgent-Monitor

# Email Alerts
EMAIL_ALERTS_ENABLED=true
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=alerts@your-domain.com
SMTP_PASSWORD=your_smtp_password
ALERT_EMAIL_FROM=alerts@your-domain.com
ALERT_EMAIL_TO=devops@your-domain.com,team@your-domain.com

# Alert Thresholds
ALERT_THRESHOLDS=critical=3,warning=5,info=10

# =============================================================================
# EXTERNAL INTEGRATIONS
# =============================================================================
# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Additional APIs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
POSTCODE_API_KEY=your_postcode_api_key

# =============================================================================
# DEVELOPMENT OVERRIDES (for development environment)
# =============================================================================
# Uncomment and modify these for development:
# ENVIRONMENT=development
# DEBUG=true
# LOG_LEVEL=DEBUG
# POSTGRES_PASSWORD=reagent_dev_password
# REDIS_PASSWORD=
# GRAFANA_PASSWORD=admin
# WEAVIATE_ANONYMOUS_ACCESS=true
# WEAVIATE_APIKEY_ENABLED=false