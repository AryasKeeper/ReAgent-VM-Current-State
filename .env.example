# ReAgent Sydney Environment Configuration

# Application Settings
APP_NAME=ReAgent Sydney
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
POSTGRES_PASSWORD=reagent_dev_password
DATABASE_URL=postgresql+asyncpg://reagent:reagent_dev_password@localhost:5432/reagent

# Cache Configuration
REDIS_URL=redis://localhost:6379/0

# Vector Database
WEAVIATE_URL=http://localhost:8080

# External API Keys
OPENAI_API_KEY=your-openai-api-key
DOMAIN_API_KEY=your-domain-api-key
REA_API_KEY=your-rea-api-key
CORELOGIC_API_KEY=your-corelogic-api-key
NSW_LPI_API_KEY=your-nsw-lpi-api-key

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Rate Limits (requests per day)
DOMAIN_RATE_LIMIT=1000
REA_RATE_LIMIT=500

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Monitoring
GRAFANA_PASSWORD=admin

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# CrewAI Configuration
CREWAI__MAX_WORKERS=4
CREWAI__TASK_TIMEOUT=300
CREWAI__RETRY_ATTEMPTS=3
CREWAI__ENABLE_LOGGING=true